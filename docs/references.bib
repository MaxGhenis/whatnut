@misc{whatnut2026prices,
  title={Retail price snapshot for raw shelled tree nuts and peanuts,
    nuts.com, April 2026},
  author={Ghenis, Max},
  year={2026},
  month=apr,
  url={https://nuts.com/},
  note={Per-kg prices for walnut, almond, pistachio, pecan, macadamia,
    peanut, hazelnut, and cashew were retrieved on 2026-04-19 from
    nuts.com product listings, choosing the cheapest raw shelled option
    per nut. Raw per-row data (retailer, product_url, package_size_g,
    package_price_usd) is stored in
    data/raw/retail_prices/retail_prices.csv; the retail_prices module in
    whatnut.data_build reads that CSV and applies the per-nut median to
    nuts.yaml. nuts.com is a single specialty retailer, so these prices
    sit toward the upper end of US retail; big-box bulk pricing (Costco,
    Sam's Club) runs 2--3x lower, shifting ICERs proportionally. Neither
    USDA ERS nor USDA NASS publishes per-species retail prices for all
    tree nuts and peanuts, so a single-retailer snapshot with a full
    audit trail is the most defensible reproducible source available.}
}

